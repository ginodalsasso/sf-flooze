{# Page header. Props: title, subtitle (text), ctaLabel + ctaHref (optional button). #}
{% props title, subtitle = null, ctaLabel = null, ctaHref = null %}

<div {{ attributes.defaults({class: 'page-header'}) }}>
    <div>
        <h1 class="page-title">{{ title }}</h1>
        {% if subtitle is not null %}
            <p class="page-subtitle">{{ subtitle }}</p>
        {% endif %}
    </div>
    {% if ctaLabel and ctaHref %}
        <div class="page-header-actions">
            {{ component('Button', {as: 'a', href: ctaHref, icon: 'plus', label: ctaLabel}) }}
        </div>
    {% endif %}
</div>
