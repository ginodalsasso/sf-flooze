{% extends 'layout/app.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'dashboard/_styles.html.twig' %}
{% endblock %}

{% block title %}Tableau de bord — Flooze{% endblock %}

{% block content %}
<twig:PageHeader :title="'Bonjour, ' ~ app.user.firstName" :subtitle="'now'|date('l d F Y')" />

<div class="page-content">
    {% if active_space %}
    <div class="active-space-badge">
        <span class="space-dot space-dot--{{ active_space.type.value }}"></span>
        <span class="active-space-name">{{ active_space.name }}</span>
        <span class="active-space-type">{{ active_space.type.value == 'professional' ? 'Professionnel' : 'Personnel' }}</span>
    </div>
    {% endif %}

    {# KPI strip #}
    <ul class="kpi-grid">
        <li class="kpi-card">
            <span class="kpi-label">Balance totale</span>
            {% if summary.hasAccounts %}
                <span class="kpi-value">{{ summary.totalBalance|number_format(2, ',', ' ') }}</span>
                <div class="kpi-trend">
                    <i data-lucide="landmark"></i>
                    <span>Solde total</span>
                </div>
            {% else %}
                <span class="kpi-value kpi-value--empty">—</span>
                <div class="kpi-trend">
                    <i data-lucide="landmark"></i>
                    Aucun compte
                </div>
            {% endif %}
        </li>
        <li class="kpi-card">
            <span class="kpi-label">Revenus du mois</span>
            <span class="kpi-value kpi-value--positive">{{ summary.monthlyIncome|number_format(2, ',', ' ') }}</span>
            <div class="kpi-trend">
                <i data-lucide="arrow-down-left" class="icon--positive"></i>
                <span>Ce mois-ci</span>
            </div>
        </li>
        <li class="kpi-card">
            <span class="kpi-label">Dépenses du mois</span>
            <span class="kpi-value kpi-value--negative">{{ summary.monthlyExpense|number_format(2, ',', ' ') }}</span>
            <div class="kpi-trend">
                <i data-lucide="arrow-up-right" class="icon--negative"></i>
                <span>Ce mois-ci</span>
            </div>
        </li>
        <li class="kpi-card">
            <span class="kpi-label">Flux net</span>
            {% set netFlowClass = summary.netFlow starts with '-' ? 'kpi-value--negative' : 'kpi-value--positive' %}
            <span class="kpi-value {{ netFlowClass }}">{{ summary.netFlow|number_format(2, ',', ' ') }}</span>
            <div class="kpi-trend">
                <i data-lucide="activity"></i>
                <span>Revenus − Dépenses</span>
            </div>
        </li>
    </ul>

    {# Main body: modules + aside #}
    <div class="dashboard-body">

        {# Left column #}
        <div class="dashboard-main">

            <div>
                <h2 class="section-title">Modules</h2>
                <ul class="module-grid">

                    <li><a href="#" class="module-card">
                        <div class="module-card-icon module-card-icon--finance">
                            <i data-lucide="landmark"></i>
                        </div>
                        <div class="module-card-body">
                            <p class="module-card-title">Finance</p>
                            <p class="module-card-desc">Comptes, transactions, catégories, actifs financiers</p>
                        </div>
                        <twig:Badge label="Bientôt disponible" variant="soon" class="module-card-badge" />
                    </a></li>

                    <li><a href="#" class="module-card">
                        <div class="module-card-icon module-card-icon--realestate">
                            <i data-lucide="building-2"></i>
                        </div>
                        <div class="module-card-body">
                            <p class="module-card-title">Immobilier</p>
                            <p class="module-card-desc">Biens, baux, locataires, emprunts</p>
                        </div>
                        <twig:Badge label="Bientôt disponible" variant="soon" class="module-card-badge" />
                    </a></li>

                    <li><a href="#" class="module-card">
                        <div class="module-card-icon module-card-icon--invoicing">
                            <i data-lucide="file-text"></i>
                        </div>
                        <div class="module-card-body">
                            <p class="module-card-title">Facturation</p>
                            <p class="module-card-desc">Clients, devis, factures, suivi paiements</p>
                        </div>
                        <twig:Badge label="Bientôt disponible" variant="soon" class="module-card-badge" />
                    </a></li>

                    <li><a href="#" class="module-card">
                        <div class="module-card-icon module-card-icon--tax">
                            <i data-lucide="receipt"></i>
                        </div>
                        <div class="module-card-body">
                            <p class="module-card-title">Impôts</p>
                            <p class="module-card-desc">Années fiscales, déclarations, optimisation</p>
                        </div>
                        <twig:Badge label="Bientôt disponible" variant="soon" class="module-card-badge" />
                    </a></li>

                    <li><a href="#" class="module-card">
                        <div class="module-card-icon module-card-icon--docs">
                            <i data-lucide="folder"></i>
                        </div>
                        <div class="module-card-body">
                            <p class="module-card-title">Documents</p>
                            <p class="module-card-desc">Coffre-fort numérique, justificatifs, archivage</p>
                        </div>
                        <twig:Badge label="Bientôt disponible" variant="soon" class="module-card-badge" />
                    </a></li>

                    <li><a href="#" class="module-card">
                        <div class="module-card-icon module-card-icon--ai">
                            <i data-lucide="scan"></i>
                        </div>
                        <div class="module-card-body">
                            <p class="module-card-title">Import IA</p>
                            <p class="module-card-desc">OCR reçus, fiches de paie, factures fournisseurs</p>
                        </div>
                        <twig:Badge label="Bientôt disponible" variant="soon" class="module-card-badge" />
                    </a></li>

                </ul>
            </div>

            {# Recent activity #}
            <div>
                <h2 class="section-title">Activité récente</h2>
                <div class="panel-card">
                    {% if summary.hasRecentActivity %}
                        <ul class="dashboard-recent-list">
                            {% for txn in summary.recentTransactions %}
                                <li class="dashboard-recent-item">
                                    <div class="dashboard-recent-main">
                                        <span class="dashboard-recent-date">{{ txn.date|date('d/m/Y') }}</span>
                                        <span class="dashboard-recent-desc">{{ txn.description ?? '—' }}</span>
                                    </div>
                                    <span class="dashboard-recent-amount dashboard-recent-amount--{{ txn.type.value }}">
                                        {% if txn.type.value == 'income' %}+{% elseif txn.type.value == 'expense' %}-{% endif %}
                                        {{ txn.amount|number_format(2, ',', ' ') }} {{ txn.account.currency.value }}
                                    </span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <twig:EmptyState
                            icon="clock"
                            text="Aucune activité récente"
                            hint="Les transactions et événements apparaîtront ici"
                        />
                    {% endif %}
                </div>
            </div>

        </div>

        {# Right column #}
        <div class="dashboard-aside">

            {# Spaces #}
            <div class="panel-card">
                <div class="panel-card-header">
                    <h3 class="section-title">Mes espaces</h3>
                    <a href="{{ path('app_space_index') }}" class="panel-card-action">Gérer</a>
                </div>
                {% if app.user.spaces|length > 0 %}
                <ul class="space-list">
                    {% for space in app.user.spaces %}
                    <li class="space-list-item{{ active_space and space.id == active_space.id ? ' space-list-item--active' : '' }}">
                        <span class="space-dot space-dot--{{ space.type.value }}"></span>
                        <div class="space-list-info">
                            <span class="space-list-name">{{ space.name }}</span>
                            <span class="space-list-type">{{ space.type.value == 'professional' ? 'Professionnel' : 'Personnel' }}</span>
                        </div>
                        {% if active_space and space.id == active_space.id %}
                            <span class="space-list-active-label">Actif</span>
                        {% else %}
                            <form method="post" action="{{ path('app_space_switch', {id: space.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('space_switch') }}">
                                <button type="submit" class="space-list-switch">Activer</button>
                            </form>
                        {% endif %}
                    </li>
                    {% endfor %}
                </ul>
                {% else %}
                <twig:EmptyState
                    icon="layout-grid"
                    text="Aucun espace"
                    hint="Créez votre premier espace pour commencer"
                    ctaLabel="Créer un espace"
                    :ctaHref="path('app_space_new')"
                />
                {% endif %}
            </div>

            {# Reminders #}
            <div class="panel-card">
                <div class="panel-card-header">
                    <h3 class="section-title">Rappels à venir</h3>
                    <a href="#" class="panel-card-action">Voir tout</a>
                </div>
                <twig:EmptyState
                    icon="bell"
                    text="Aucun rappel"
                    hint="Échéances, loyers et déclarations apparaîtront ici"
                />
            </div>

            {# Quick actions #}
            <div class="panel-card">
                <h3 class="section-title">Actions rapides</h3>
                <div class="quick-actions">
                    <button type="button" class="quick-action-btn" disabled>
                        <i data-lucide="plus"></i>
                        Nouvelle transaction
                    </button>
                    <button type="button" class="quick-action-btn" disabled>
                        <i data-lucide="scan"></i>
                        Scanner un reçu
                    </button>
                    <button type="button" class="quick-action-btn" disabled>
                        <i data-lucide="file-text"></i>
                        Nouveau devis
                    </button>
                </div>
            </div>

        </div>
    </div>

</div>
{% endblock %}
