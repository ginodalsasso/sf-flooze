{% set _sid = app.session.get('flooze_active_space_id') %}
{% set _active_space = null %}
{% for _s in app.user.spaces %}
    {% if _s.id == _sid %}{% set _active_space = _s %}{% endif %}
{% endfor %}
{% if _active_space is null and app.user.spaces|length > 0 %}
    {% set _active_space = app.user.spaces.first() %}
{% endif %}

{% set _route = app.request.attributes.get('_route') %}

<aside class="app-sidebar">
    <div class="sidebar-header">
        <div class="sidebar-logo">
            <div class="sidebar-logo-mark">
                <i data-lucide="trending-up"></i>
            </div>
            <span class="sidebar-logo-name">Flooze</span>
        </div>

        {% if app.user.spaces|length > 0 %}
        <details class="space-switcher">
            <summary class="space-switcher-btn">
                <span class="space-dot space-dot--{{ _active_space ? _active_space.type.value : 'personal' }}"></span>
                <span class="space-switcher-name">{{ _active_space ? _active_space.name : 'Aucun espace' }}</span>
                <span class="space-switcher-type">{{ _active_space ? (_active_space.type.value == 'professional' ? 'Pro' : 'Personnel') : '' }}</span>
                <i data-lucide="chevrons-up-down" class="space-switcher-chevron"></i>
            </summary>
            <div class="space-switcher-dropdown">
                {% for space in app.user.spaces %}
                <form method="post" action="{{ path('app_space_switch', {id: space.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('space_switch') }}">
                    <button type="submit" class="space-option{{ _active_space and space.id == _active_space.id ? ' space-option--active' : '' }}">
                        <span class="space-dot space-dot--{{ space.type.value }}"></span>
                        <div class="space-option-info">
                            <span class="space-option-name">{{ space.name }}</span>
                            <span class="space-option-type">{{ space.type.value == 'professional' ? 'Professionnel' : 'Personnel' }}</span>
                        </div>
                        {% if _active_space and space.id == _active_space.id %}
                        <i data-lucide="check" class="space-option-check"></i>
                        {% endif %}
                    </button>
                </form>
                {% endfor %}
                <div class="space-switcher-divider"></div>
                {% if app.user.spaces|length < 2 %}
                <a href="{{ path('app_space_new') }}" class="space-option space-option--action">
                    <i data-lucide="plus" class="space-action-icon"></i>
                    <span class="space-action-label">Créer un espace</span>
                </a>
                {% endif %}
                <a href="{{ path('app_space_index') }}" class="space-option space-option--action">
                    <i data-lucide="settings-2" class="space-action-icon"></i>
                    <span class="space-action-label">Gérer les espaces</span>
                </a>
            </div>
        </details>
        {% else %}
        <a href="{{ path('app_space_new') }}" class="space-create-btn">
            <i data-lucide="plus-circle"></i>
            Créer un espace
        </a>
        {% endif %}
    </div>

    <nav class="sidebar-nav">
        <a href="{{ path('app_home') }}" class="nav-item{{ _route == 'app_home' ? ' is-active' : '' }}">
            <i data-lucide="layout-dashboard"></i>
            Tableau de bord
        </a>

        <span class="nav-section-label">Finance</span>
        <a href="{{ path('app_account_index') }}" class="nav-item{{ _route starts with 'app_account_' ? ' is-active' : '' }}">
            <i data-lucide="landmark"></i>
            Comptes
        </a>
        <a href="{{ path('app_transaction_index') }}" class="nav-item{{ _route == 'app_transaction_index' ? ' is-active' : '' }}">
            <i data-lucide="arrow-left-right"></i>
            Transactions
        </a>
        <a href="{{ path('app_category_index') }}" class="nav-item{{ _route starts with 'app_category_' ? ' is-active' : '' }}">
            <i data-lucide="tag"></i>
            Catégories
        </a>
        <a href="{{ path('app_asset_index') }}" class="nav-item{{ _route starts with 'app_asset_' ? ' is-active' : '' }}">
            <i data-lucide="trending-up"></i>
            Actifs
        </a>

        <span class="nav-section-label">Patrimoine</span>
        <details class="nav-group">
            <summary>
                <i data-lucide="building-2"></i>
                Immobilier
                <i data-lucide="chevron-right" class="nav-group-chevron"></i>
            </summary>
            <div class="nav-group-items">
                <a href="#" class="nav-item nav-item--sub">
                    <i data-lucide="home"></i>
                    Biens
                </a>
                <a href="#" class="nav-item nav-item--sub">
                    <i data-lucide="file-signature"></i>
                    Baux
                </a>
                <a href="#" class="nav-item nav-item--sub">
                    <i data-lucide="users"></i>
                    Locataires
                </a>
                <a href="#" class="nav-item nav-item--sub">
                    <i data-lucide="banknote"></i>
                    Emprunts
                </a>
            </div>
        </details>

        <span class="nav-section-label">Pro</span>
        <details class="nav-group">
            <summary>
                <i data-lucide="file-text"></i>
                Facturation
                <i data-lucide="chevron-right" class="nav-group-chevron"></i>
            </summary>
            <div class="nav-group-items">
                <a href="#" class="nav-item nav-item--sub">
                    <i data-lucide="briefcase"></i>
                    Clients
                </a>
                <a href="#" class="nav-item nav-item--sub">
                    <i data-lucide="clipboard-list"></i>
                    Devis
                </a>
                <a href="#" class="nav-item nav-item--sub">
                    <i data-lucide="receipt"></i>
                    Factures
                </a>
            </div>
        </details>
        <details class="nav-group">
            <summary>
                <i data-lucide="calculator"></i>
                Impôts
                <i data-lucide="chevron-right" class="nav-group-chevron"></i>
            </summary>
            <div class="nav-group-items">
                <a href="#" class="nav-item nav-item--sub">
                    <i data-lucide="calendar-range"></i>
                    Années fiscales
                </a>
                <a href="#" class="nav-item nav-item--sub">
                    <i data-lucide="list-checks"></i>
                    Éléments fiscaux
                </a>
            </div>
        </details>

        <span class="nav-section-label">Outils</span>
        <a href="#" class="nav-item">
            <i data-lucide="folder"></i>
            Documents
        </a>
        <a href="#" class="nav-item">
            <i data-lucide="scan"></i>
            Import IA
        </a>
        <a href="#" class="nav-item">
            <i data-lucide="bell"></i>
            Rappels
        </a>
    </nav>

    <div class="sidebar-footer">
        <button class="sidebar-action" type="button" onclick="toggleTheme()" id="themeToggleBtn">
            <i data-lucide="sun" id="themeIcon"></i>
            <span id="themeLabel">Mode clair</span>
        </button>
        <div class="sidebar-user">
            <div class="sidebar-user-avatar">
                {{ app.user.firstName|slice(0,1)|upper }}{{ app.user.lastName|slice(0,1)|upper }}
            </div>
            <div class="sidebar-user-info">
                <div class="sidebar-user-name">{{ app.user.fullName }}</div>
                <div class="sidebar-user-email">{{ app.user.email }}</div>
            </div>
        </div>
        <a href="{{ path('app_logout') }}" class="sidebar-action">
            <i data-lucide="log-out"></i>
            Se déconnecter
        </a>
    </div>
</aside>

<script>
document.addEventListener('click', function (e) {
    const d = document.querySelector('details.space-switcher');
    if (d && !d.contains(e.target)) d.removeAttribute('open');
});

function toggleTheme() {
    const next = (document.documentElement.getAttribute('data-theme') || 'dark') === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('flooze-theme', next);
    const icon = document.getElementById('themeIcon');
    const label = document.getElementById('themeLabel');
    if (icon) { icon.setAttribute('data-lucide', next === 'dark' ? 'sun' : 'moon'); lucide?.createIcons(); }
    if (label) label.textContent = next === 'dark' ? 'Mode clair' : 'Mode sombre';
}

(function () {
    const theme = localStorage.getItem('flooze-theme') || 'dark';
    const icon = document.getElementById('themeIcon');
    const label = document.getElementById('themeLabel');
    if (icon) { icon.setAttribute('data-lucide', theme === 'dark' ? 'sun' : 'moon'); lucide?.createIcons(); }
    if (label) label.textContent = theme === 'dark' ? 'Mode clair' : 'Mode sombre';
})();
</script>
