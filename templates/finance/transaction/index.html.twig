{% extends 'layout/app.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'finance/transaction/_styles.html.twig' %}
{% endblock %}

{% block title %}Transactions — Flooze{% endblock %}

{% block content %}
<twig:PageHeader
    title="Transactions"
    subtitle="Historique de tous tes mouvements financiers"
    ctaLabel="Nouvelle transaction"
    ctaHref="{{ path('app_transaction_new') }}"
/>

<div class="page-content">
    <twig:Flash />

    {# Filters #}
    <div class="txn-filters">
        <a href="{{ path('app_transaction_index') }}"
           class="txn-filter-btn{{ typeFilter is null and accountFilter is null ? ' txn-filter-btn--active' : '' }}">
            <i data-lucide="list"></i> Tout
        </a>
        <a href="{{ path('app_transaction_index', {type: 'income'}) }}"
           class="txn-filter-btn{{ typeFilter and typeFilter.value == 'income' ? ' txn-filter-btn--active' : '' }}">
            <i data-lucide="arrow-down-left"></i> Revenus
        </a>
        <a href="{{ path('app_transaction_index', {type: 'expense'}) }}"
           class="txn-filter-btn{{ typeFilter and typeFilter.value == 'expense' ? ' txn-filter-btn--active' : '' }}">
            <i data-lucide="arrow-up-right"></i> Dépenses
        </a>
        <a href="{{ path('app_transaction_index', {type: 'transfer'}) }}"
           class="txn-filter-btn{{ typeFilter and typeFilter.value == 'transfer' ? ' txn-filter-btn--active' : '' }}">
            <i data-lucide="arrow-left-right"></i> Virements
        </a>

        {% if accounts|length > 0 %}
            {% for account in accounts %}
                <a href="{{ path('app_transaction_index', {account: account.id}) }}"
                   class="txn-filter-btn{{ accountFilter and accountFilter.id == account.id ? ' txn-filter-btn--active' : '' }}">
                    <i data-lucide="{{ account.type.icon() }}"></i> {{ account.name }}
                </a>
            {% endfor %}
        {% endif %}
    </div>

    {% if transactions|length > 0 %}
        <div class="txn-table-wrap">
            <table class="txn-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Compte</th>
                        <th>Type</th>
                        <th style="text-align:right">Montant</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for txn in transactions %}
                        <tr>
                            <td>
                                <span class="txn-date">{{ txn.date|date('d/m/Y') }}</span>
                            </td>
                            <td>
                                <div class="txn-desc">{{ txn.description ?? '—' }}</div>
                                {% if txn.category %}
                                    <div class="txn-cat">{{ txn.category.name }}</div>
                                {% endif %}
                            </td>
                            <td>
                                <span class="txn-account">{{ txn.account.name }}</span>
                                {% if txn.destinationAccount %}
                                    <div class="txn-cat">→ {{ txn.destinationAccount.name }}</div>
                                {% endif %}
                            </td>
                            <td>
                                <twig:Badge
                                    label="{{ txn.type.label() }}"
                                    variant="{{ txn.type.badgeVariant() }}"
                                />
                            </td>
                            <td>
                                <span class="txn-amount txn-amount--{{ txn.type.value }}">
                                    {% if txn.type.value == 'income' %}+{% elseif txn.type.value == 'expense' %}-{% endif %}
                                    {{ txn.amount|number_format(2, ',', ' ') }} {{ txn.account.currency }}
                                </span>
                            </td>
                            <td>
                                <div class="txn-actions">
                                    <twig:Button
                                        as="a"
                                        href="{{ path('app_transaction_edit', {id: txn.id}) }}"
                                        icon="pencil"
                                        label="Modifier"
                                        variant="secondary"
                                    />
                                    {% include 'finance/transaction/forms/_delete.html.twig' with {transaction: txn} %}
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <twig:EmptyState
            icon="arrow-left-right"
            text="Aucune transaction"
            hint="Enregistre ton premier mouvement financier pour commencer le suivi."
            ctaLabel="Nouvelle transaction"
            ctaHref="{{ path('app_transaction_new') }}"
        />
    {% endif %}
</div>
{% endblock %}
