{% extends 'layout/app.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'finance/transaction/_styles.html.twig' %}
{% endblock %}

{% block title %}Nouvelle transaction — Flooze{% endblock %}

{% block content %}
<twig:PageHeader title="Nouvelle transaction" subtitle="Enregistre un revenu, une dépense ou un virement" />

<div class="page-content">
    <div class="form-page">
        <twig:Flash levels="{{ ['error'] }}" />
        {% include 'finance/transaction/forms/_form.html.twig' with {submit_label: 'Enregistrer'} %}
    </div>
</div>
{% endblock %}
