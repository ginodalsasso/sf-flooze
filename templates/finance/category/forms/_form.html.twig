{{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

    <div class="form-section">
        <twig:Form:Field field="{{ form.name }}" label="Nom de la catégorie" />
    </div>

    <div class="form-section">
        <twig:Form:Field field="{{ form.parent }}" label="Catégorie parente"
                         hint="Laisse vide pour une catégorie racine" />
    </div>

    <div class="form-section">
        <p class="form-section-label" title="Indiquez si cette catégorie a un impact fiscal sur vos déclarations">Flags fiscaux</p>
        <div class="cat-form-flags">
            <twig:Form:CheckboxField field="{{ form.isDeductible }}"
                                     label="Charge déductible"
                                     hint="Cette charge réduit votre revenu imposable (ex : frais pro, cotisations)" />
            <twig:Form:CheckboxField field="{{ form.isDeclarable }}"
                                     label="Revenu déclarable"
                                     hint="Ce revenu doit être déclaré aux impôts (ex : salaire, loyer perçu)" />
        </div>
    </div>

    <div class="form-actions">
        <twig:Button as="a" href="{{ path('app_category_index') }}" label="Annuler" variant="secondary" />
        <twig:Button type="submit" icon="check" label="{{ submit_label }}" />
    </div>

{{ form_end(form) }}
