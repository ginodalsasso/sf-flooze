{% extends 'layout/app.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'finance/category/_styles.html.twig' %}
{% endblock %}

{% block title %}Modifier « {{ category.name }} » — Flooze{% endblock %}

{% block content %}
<twig:PageHeader title="Modifier la catégorie" subtitle="{{ category.name }}" />

<div class="page-content">
    <div class="form-page">
        <twig:Flash levels="{{ ['error'] }}" />
        {% include 'finance/category/forms/_form.html.twig' with {submit_label: 'Enregistrer'} %}
    </div>
</div>
{% endblock %}
