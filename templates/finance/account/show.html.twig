{% extends 'layout/app.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'finance/account/_styles.html.twig' %}
    {% include 'finance/transaction/_styles.html.twig' %}
{% endblock %}

{% block title %}{{ detail.account.name }} — Flooze{% endblock %}

{% block content %}
<twig:PageHeader
    title="{{ detail.account.name }}"
    subtitle="Détail du compte et historique des mouvements"
    ctaLabel="Nouvelle transaction"
    ctaHref="{{ path('app_transaction_new') }}"
/>

<div class="page-content">
    <twig:Flash />

    {# Account summary card #}
    <div class="acc-show-summary">
        <div class="acc-show-meta">
            <div class="acc-card-icon">
                <i data-lucide="{{ detail.account.type.icon() }}"></i>
            </div>
            <div>
                <p class="acc-card-name">{{ detail.account.name }}</p>
                <twig:Badge
                    label="{{ detail.account.type.label() }}"
                    variant="{{ detail.account.type.badgeVariant() }}"
                />
            </div>
        </div>
        <div class="acc-show-balance">
            {% set balance = detail.account.balance %}
            <p class="acc-card-balance{% if balance < 0 %} acc-card-balance--negative{% elseif balance > 0 %} acc-card-balance--positive{% endif %}">
                {{ balance|number_format(2, ',', ' ') }} {{ detail.account.currency.value }}
            </p>
            <p class="acc-card-currency">Solde actuel</p>
        </div>
        <div class="acc-show-actions">
            <twig:Button
                as="a"
                href="{{ path('app_account_edit', {id: detail.account.id}) }}"
                icon="pencil"
                label="Modifier le compte"
                variant="secondary"
            />
        </div>
    </div>

    {# Monthly summary #}
    <div class="acc-show-monthly">
        <div class="acc-show-monthly-item">
            <span class="acc-show-monthly-label">Revenus ce mois</span>
            <span class="acc-show-monthly-value acc-show-monthly-value--positive">+{{ detail.monthlyIncome|number_format(2, ',', ' ') }} {{ detail.account.currency.value }}</span>
        </div>
        <div class="acc-show-monthly-item">
            <span class="acc-show-monthly-label">Dépenses ce mois</span>
            <span class="acc-show-monthly-value acc-show-monthly-value--negative">-{{ detail.monthlyExpense|number_format(2, ',', ' ') }} {{ detail.account.currency.value }}</span>
        </div>
        <div class="acc-show-monthly-item">
            <span class="acc-show-monthly-label">Flux net</span>
            {% set netFlow = detail.monthlyNetFlow %}
            <span class="acc-show-monthly-value {{ netFlow starts with '-' ? 'acc-show-monthly-value--negative' : 'acc-show-monthly-value--positive' }}">
                {{ netFlow|number_format(2, ',', ' ') }} {{ detail.account.currency.value }}
            </span>
        </div>
    </div>

    {# Transactions list #}
    <h2 class="acc-show-section-title">Mouvements</h2>

    {% if detail.hasTransactions %}
        <div class="txn-table-wrap">
            <table class="txn-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Catégorie</th>
                        <th>Type</th>
                        <th class="txn-table__amount-header">Montant</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for txn in detail.transactions %}
                        <tr>
                            <td>
                                <span class="txn-date">{{ txn.date|date('d/m/Y') }}</span>
                            </td>
                            <td>
                                <div class="txn-desc">{{ txn.description ?? '—' }}</div>
                                {% if txn.destinationAccount %}
                                    <div class="txn-cat">→ {{ txn.destinationAccount.name }}</div>
                                {% endif %}
                            </td>
                            <td>
                                {% set categoryLabel = txn.categoryLabel %}
                                {% if categoryLabel %}
                                    <span class="txn-account">{{ categoryLabel }}</span>
                                {% else %}
                                    <span class="txn-account txn-account--muted">—</span>
                                {% endif %}
                            </td>
                            <td>
                                <twig:Badge
                                    label="{{ txn.type.label() }}"
                                    variant="{{ txn.type.badgeVariant() }}"
                                />
                            </td>
                            <td>
                                <span class="txn-amount txn-amount--{{ txn.type.value }}">
                                    {% if txn.type.value == 'income' %}+{% elseif txn.type.value == 'expense' %}-{% endif %}
                                    {{ txn.amount|number_format(2, ',', ' ') }} {{ detail.account.currency.value }}
                                </span>
                            </td>
                            <td>
                                <div class="txn-actions">
                                    <twig:Button
                                        as="a"
                                        href="{{ path('app_transaction_edit', {id: txn.id, redirect_to: path('app_account_show', {id: detail.account.id})}) }}"
                                        icon="pencil"
                                        label="Modifier"
                                        variant="secondary"
                                    />
                                    {% include 'finance/transaction/forms/_delete.html.twig' with {
                                        transaction: txn,
                                        redirect_to: path('app_account_show', {id: detail.account.id})
                                    } %}
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <twig:EmptyState
            icon="arrow-left-right"
            text="Aucun mouvement"
            hint="Ce compte n'a pas encore de transactions enregistrées."
            ctaLabel="Nouvelle transaction"
            ctaHref="{{ path('app_transaction_new') }}"
        />
    {% endif %}
</div>
{% endblock %}
