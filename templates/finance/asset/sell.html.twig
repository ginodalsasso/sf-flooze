{% extends 'layout/app.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'finance/asset/_styles.html.twig' %}
{% endblock %}

{% block title %}Vendre {{ asset.ticker }} — Flooze{% endblock %}

{% block content %}
<twig:PageHeader
    title="Vendre {{ asset.ticker }}"
    subtitle="Enregistrer une vente de {{ asset.name }}"
    ctaLabel="Annuler"
    ctaHref="{{ path('app_asset_show', {id: asset.id}) }}"
/>

<div class="page-content">
    <div class="form-page">
        <twig:Flash levels="{{ ['error'] }}" />

        <div class="form-section" style="margin-bottom: 20px;">
            <p style="color: var(--fg-3); font-size: 13px;">
                Quantité détenue : <strong style="color: var(--fg-1);">{{ asset.totalQuantity|number_format(8, ',', ' ')|replace({',00000000': ''}) }}</strong> unités
            </p>
        </div>

        {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
            <div class="form-section acc-form-row">
                <twig:Form:Field field="{{ form.date }}" label="Date de vente" />
                <twig:Form:Field field="{{ form.quantity }}" label="Quantité vendue" />
            </div>
            <div class="form-section acc-form-row">
                <twig:Form:Field field="{{ form.unitPrice }}" label="Prix unitaire" />
                <twig:Form:Field field="{{ form.fxRate }}" label="Taux de change" />
            </div>

            <div class="form-section" style="margin-bottom: 8px;">
                <p style="color: var(--fg-3); font-size: 12px; line-height: 1.5;">
                    <strong>Taux de change</strong> : prix de 1 {{ asset.currency.value }} en euros au moment de la vente.
                    {% if asset.currency.value == 'EUR' %}
                        Laissez 1,000000 car l'actif est en euros.
                    {% else %}
                        Exemple : si 1 {{ asset.currency.value }} = 0,92 €, saisissez <strong>0,920000</strong>.
                    {% endif %}
                </p>
            </div>

            <div class="form-section acc-form-row">
                <twig:Form:Field field="{{ form.fees }}" label="Frais de transaction" />
                <twig:Form:Field field="{{ form.account }}" label="Compte de détention" />
            </div>
            <div class="form-section acc-form-row">
                <twig:Form:Field field="{{ form.fundingAccount }}" label="Compte de destination" />
                <twig:Form:Field field="{{ form.note }}" label="Note" />
            </div>

            <div class="form-actions">
                <twig:Button as="a" href="{{ path('app_asset_show', {id: asset.id}) }}" label="Annuler" variant="secondary" />
                <twig:Button type="submit" icon="check" label="Enregistrer la vente" />
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
