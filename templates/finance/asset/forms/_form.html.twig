{{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

    <div class="form-section acc-form-row">
        <twig:Form:Field field="{{ form.ticker }}" label="Ticker"
                         hint="Code boursier de l'actif : AAPL, BTC, MSFT, EURUSD…" />
        <twig:Form:Field field="{{ form.type }}" label="Type d'actif" />
    </div>

    <div class="form-section">
        <twig:Form:Field field="{{ form.name }}" label="Nom de l'actif" />
    </div>

    <div class="form-section acc-form-row">
        <twig:Form:Field field="{{ form.currency }}" label="Devise de l'actif" />
        <twig:Form:Field field="{{ form.account }}" label="Compte de détention"
                         hint="Le compte doit correspondre au type d'actif (crypto, actions/ETF...)." />
    </div>

    <div class="form-section acc-form-row">
        <twig:Form:Field field="{{ form.fundingAccount }}" label="Compte de paiement"
                         hint="Compte débité pour financer cet achat." />
    </div>

    <hr class="form-divider">
    <h3 class="form-section-title">Achat initial</h3>

    <div class="form-section acc-form-row">
        <twig:Form:Field field="{{ form.entryDate }}" label="Date d'achat" />
        <twig:Form:Field field="{{ form.entryQuantity }}" label="Quantité achetée" />
    </div>

    <div class="form-section acc-form-row">
        <twig:Form:Field field="{{ form.entryUnitPrice }}" label="Prix unitaire" />
        <twig:Form:Field field="{{ form.entryFxRate }}" label="Taux de change" hint="Si la devise de l’actif diffère de l’euro, renseignez le taux de change (ex. : 0,920000) ; sinon, indiquez 1,000000." />
    </div>

    <div class="form-section acc-form-row">
        <twig:Form:Field field="{{ form.entryFees }}" label="Frais de transaction" />
    </div>

    <div class="form-actions">
        <twig:Button as="a" href="{{ path('app_asset_index') }}" label="Annuler" variant="secondary" />
        <twig:Button type="submit" icon="check" label="{{ submit_label }}" />
    </div>

{{ form_end(form) }}
