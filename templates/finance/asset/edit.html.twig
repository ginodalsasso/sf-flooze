{% extends 'layout/app.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'finance/asset/_styles.html.twig' %}
{% endblock %}

{% block title %}Modifier « {{ asset.ticker }} » — Flooze{% endblock %}

{% block content %}
<twig:PageHeader title="Modifier l'actif" subtitle="{{ asset.ticker }} — {{ asset.name }}" />

<div class="page-content">
    <div class="form-page">
        <twig:Flash levels="{{ ['error'] }}" />
        {% include 'finance/asset/forms/_form.html.twig' with {submit_label: 'Enregistrer'} %}
    </div>
</div>
{% endblock %}
