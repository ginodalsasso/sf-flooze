<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify your Flooze account</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500&family=Syne:wght@600;700&display=swap" rel="stylesheet">
    {% include 'emails/_styles.html.twig' %}
</head>
<body>
<div class="container">
    <div class="header">
        <h1>Flooze</h1>
    </div>
    <div class="body">
        <p>Hello {{ user.firstName }},</p>
        <p>Thank you for creating your Flooze account. Please verify your email address by clicking the button below.</p>
        <a href="{{ verifyUrl }}" class="btn">Verify my email</a>
        <p>This link will expire in <strong>24 hours</strong>.</p>
        <p>If the button does not work, copy and paste the following link into your browser:</p>
        <p class="url">{{ verifyUrl }}</p>
        <p>If you did not create this account, you can safely ignore this email.</p>
    </div>
    <div class="footer">
        <p>This is an automated message from Flooze. Please do not reply to this email.</p>
    </div>
</div>
</body>
</html>
