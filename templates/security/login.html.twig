{% extends 'base.html.twig' %}

{% block title %}Connexion — Flooze{% endblock %}

{% block body %}
<div class="auth-wrapper">
    <div class="auth-card">
        <h1>Connexion</h1>

        <twig:Flash />

        {% if error %}
            <div class="flash flash--error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post">
            <div class="form-group">
                <label for="inputEmail">Email</label>
                <input type="email" id="inputEmail" name="_username" value="{{ last_username }}"
                       autocomplete="email" required autofocus>
            </div>

            <div class="form-group">
                <label for="inputPassword">Mot de passe</label>
                <input type="password" id="inputPassword" name="_password"
                       autocomplete="current-password" required>
            </div>

            <div class="form-group form-group--checkbox">
                <input type="checkbox" id="rememberMe" name="_remember_me">
                <label for="rememberMe">Se souvenir de moi 7 jours</label>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <twig:Button label="Se connecter" type="submit" class="btn--full btn--mt" />
        </form>

        <p class="auth-link">Pas encore de compte ? <a href="{{ path('app_register') }}">En créer un</a></p>
    </div>
</div>
{% endblock %}
