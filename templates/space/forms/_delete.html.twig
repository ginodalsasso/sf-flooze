{% block content %}
    <form
        method="post"
        action="{{ path('app_space_delete', {'id': space.id}) }}"
        onsubmit="return confirm('Supprimer l\'espace « {{ space.name }} » ?\n\nToutes les données associées seront définitivement supprimées.')"
    >
        <input type="hidden" name="_token" value="{{ csrf_token('space_delete_' ~ space.id) }}">
        <twig:Button type="submit" icon="trash-2" label="Supprimer" variant="danger" />
    </form>
{% endblock %}
