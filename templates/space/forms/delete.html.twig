{% block content %}
    <form 
        method="post" 
        action="{{ path('app_space_delete', {'id': space.id}) }}"
        onsubmit=
            "return confirm('Supprimer l\'espace « {{ space.name }} » ?\n\nToutes les données associées seront définitivement supprimées.')"
    >
        <input type="hidden" name="_token" value="{{ csrf_token('space_delete_' ~ space.id) }}">
        <button type="submit" class="btn btn--danger">
            <i data-lucide="trash-2"></i>
            Supprimer
        </button>
    </form>
{% endblock %}