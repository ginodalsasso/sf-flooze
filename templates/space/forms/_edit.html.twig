{% block content %}
    {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

        <div class="form-section">
            <p class="form-section-label">Type d'espace</p>
            <div class="type-card-readonly">
                <twig:SpaceTypeIcon type="{{ space.type.value }}" size="md" />
                <div class="type-card-body">
                    <div class="type-card-title">{{ space.type.value == 'professional' ? 'Professionnel' : 'Personnel' }}</div>
                    <div class="type-card-desc">Le type d'espace ne peut pas être modifié après la création</div>
                </div>
                <span class="type-card-taken-badge">Verrouillé</span>
            </div>
        </div>

        {# Name field #}
        <div class="form-section">
            <twig:Form:Field field="{{ form.name }}" label="Nom de l'espace" />
        </div>

        {# Actions #}
        <div class="form-actions">
            <twig:Button as="a" href="{{ path('app_home') }}" label="Annuler" variant="secondary" />
            <twig:Button type="submit" icon="check" label="Enregistrer" />
        </div>
    {{ form_end(form) }}
{% endblock %}
