{% block content %}
    {{ form_start(form, {attr: {id: 'spaceForm', novalidate: 'novalidate'}}) }}
        {# Type selector #}
        <div class="form-section">
            <p class="form-section-label">Type d'espace</p>
            <div class="space-type-selector">
                {% for type_choice in form.type %}
                    {% set is_personal = type_choice.vars.value == 'personal' %}
                    {% set is_taken    = (is_personal and has_personal) or (not is_personal and has_pro) %}
                    <label
                        for="{{ type_choice.vars.id }}"
                        class="type-card{{ is_taken ? ' type-card--disabled' : '' }}"
                        data-suggested="{{ is_personal ? 'Mes finances' : 'Mon activité pro' }}"
                    >
                        {{ form_widget(type_choice, {attr: {class: 'sr-only', disabled: is_taken ? 'disabled' : false}}) }}
                        <twig:SpaceTypeIcon type="{{ type_choice.vars.value }}" size="md" />
                        <div class="type-card-body">
                            <div class="type-card-title">{{ is_personal ? 'Personnel' : 'Professionnel' }}</div>
                            <div class="type-card-desc">
                                {% if is_personal %}
                                    Comptes perso, budget, patrimoine, impôts personnels
                                {% else %}
                                    Facturation clients, TVA, charges pro, déclarations
                                {% endif %}
                            </div>
                        </div>
                        {% if is_taken %}
                            <span class="type-card-taken-badge">Déjà créé</span>
                        {% endif %}
                    </label>
                {% endfor %}
            </div>
            {% for error in form.type.vars.errors %}
                <span class="form-error">{{ error.message }}</span>
            {% endfor %}
        </div>

        {# Name field #}
        <div class="form-section">
            <twig:Form:Field field="{{ form.name }}"
                             label="Nom de l'espace"
                             hint="Choisis un nom qui identifie clairement cet espace" />
        </div>

        {# Actions #}
        <div class="form-actions">
            <twig:Button as="a" href="{{ path('app_home') }}" label="Annuler" variant="secondary" />
            <twig:Button type="submit" icon="plus" label="Créer l'espace" />
        </div>

    {{ form_end(form) }}
{% endblock %}
