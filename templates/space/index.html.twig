{% extends 'layout/app.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'space/_styles.html.twig' %}
{% endblock %}

{% block title %}Mes espaces — Flooze{% endblock %}

{% block content %}
{% set _has_personal = false %}
{% set _has_pro = false %}
{% for s in spaces %}
    {% if s.type.value == 'personal' %}{% set _has_personal = true %}{% endif %}
    {% if s.type.value == 'professional' %}{% set _has_pro = true %}{% endif %}
{% endfor %}

<twig:PageHeader title="Mes espaces" subtitle="Gérez vos espaces personnel et professionnel">
    {% block actions %}
        {% if not (_has_personal and _has_pro) %}
            <twig:Button as="a" href="{{ path('app_space_new') }}" icon="plus" label="Créer un espace" />
        {% endif %}
    {% endblock %}
</twig:PageHeader>

<div class="page-content">

    <twig:Flash />

    {% if spaces|length > 0 %}
    <div class="spaces-list-full">
        {% for space in spaces %}
        <div class="space-full-card">
            <twig:SpaceTypeIcon type="{{ space.type.value }}" size="lg" />
            <div class="space-full-body">
                <div class="space-full-name">{{ space.name }}</div>
                <div class="space-full-meta">
                    <span class="space-dot space-dot--{{ space.type.value }} space-dot--sm"></span>
                    {{ space.type.value == 'professional' ? 'Professionnel' : 'Personnel' }}
                    &middot; créé le {{ space.createdAt|date('d/m/Y') }}
                </div>
            </div>
            <div class="space-full-actions">
                <twig:Button as="a" href="{{ path('app_space_edit', {'id': space.id}) }}"
                             icon="pencil" label="Modifier" variant="secondary" />
                {% include 'space/forms/_delete.html.twig' with {space: space} %}
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <div class="panel-card panel-card--constrained">
        <div class="panel-empty panel-empty--padded">
            <div class="panel-empty-icon"><i data-lucide="layers"></i></div>
            <p class="panel-empty-text">Aucun espace créé</p>
            <p class="panel-empty-hint">Un espace personnel et un espace professionnel te permettent de séparer tes finances</p>
        </div>
        <div class="panel-cta">
            <twig:Button as="a" href="{{ path('app_space_new') }}" icon="plus" label="Créer mon premier espace" />
        </div>
    </div>
    {% endif %}

</div>
{% endblock %}
