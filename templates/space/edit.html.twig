{% extends 'layout/app.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'space/_styles.html.twig' %}
{% endblock %}

{% block title %}Modifier l'espace — Flooze{% endblock %}

{% block content %}
<twig:PageHeader
    title="Modifier l'espace"
    :subtitle="space.type.value == 'professional' ? 'Professionnel' : 'Personnel'"
/>

<div class="page-content">
    <div class="form-page">
        <twig:Flash levels="{{ ['error'] }}" />
        {% include 'space/forms/_edit.html.twig' %}
    </div>
</div>
{% endblock %}
