{% extends 'layout/app.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'space/_styles.html.twig' %}
{% endblock %}

{% block title %}Créer un espace — Flooze{% endblock %}

{% block content %}
<twig:PageHeader title="Créer un espace"
                 subtitle="Un espace regroupe toutes tes données financières personnelles ou professionnelles" />

<div class="page-content">
    <div class="form-page">
        <twig:Flash levels="{{ ['error'] }}" />
        {% include 'space/forms/_new.html.twig' %}
    </div>
</div>

<script>
// Auto-suggest name based on type selection, but only if the user hasn't typed a custom name
(function () {
    const nameInput = document.getElementById('{{ form.name.vars.id }}');
    document.querySelectorAll('.type-card:not(.type-card--disabled)').forEach(card => {
        card.addEventListener('click', () => {
            const radio = card.querySelector('input[type="radio"]');
            if (!radio || radio.disabled) return;
            const suggested = card.dataset.suggested;
            if (suggested && (!nameInput.value || nameInput.dataset.auto === 'true')) {
                nameInput.value = suggested;
                nameInput.dataset.auto = 'true';
            }
        });
    });
    nameInput.addEventListener('input', () => { nameInput.dataset.auto = 'false'; });
})();
</script>
{% endblock %}
