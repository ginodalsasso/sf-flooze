{% extends 'base.html.twig' %}

{% block title %}Créer un compte — Flooze{% endblock %}

{% block body %}
<div class="auth-wrapper">
    <div class="auth-card">
        <h1>Créer un compte</h1>

        <twig:Flash :levels="['error']" />

        {{ form_start(registrationForm) }}

            <twig:Form:Field :field="registrationForm.firstName" label="Prénom" />
            <twig:Form:Field :field="registrationForm.lastName" label="Nom" />
            <twig:Form:Field :field="registrationForm.email" label="Adresse email" />
            <twig:Form:Field
                :field="registrationForm.plainPassword.first"
                label="Mot de passe"
                hint="Min. 12 caractères avec majuscule, minuscule, chiffre et caractère spécial."
            />
            <twig:Form:Field :field="registrationForm.plainPassword.second" label="Confirmer le mot de passe" />

            {{ form_errors(registrationForm.plainPassword) }}

            <twig:Form:CheckboxField :field="registrationForm.agreeTerms" label="J'accepte les conditions d'utilisation" />

            <twig:Button label="Créer mon compte" type="submit" class="btn--full btn--mt" />

        {{ form_end(registrationForm) }}

        <p class="auth-link">Déjà un compte ? <a href="{{ path('app_login') }}">Se connecter</a></p>
    </div>
</div>
{% endblock %}
